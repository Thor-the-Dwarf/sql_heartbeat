{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./folderTree.schema.json",
  "title": "SQL Heartbeat Folder Tree",
  "type": "object",
  "additionalProperties": false,
  "required": ["rootLabel", "tools"],
  "properties": {
    "rootLabel": {
      "type": "string",
      "minLength": 1
    },
    "tools": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tool"
      }
    }
  },
  "$defs": {
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label"],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "lessons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lesson"
          }
        },
        "lessonRoots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lesson"
          }
        }
      },
      "anyOf": [
        { "required": ["lessons"] },
        { "required": ["lessonRoots"] }
      ]
    },
    "task": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["text"],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "text": {
              "type": "string",
              "minLength": 1
            },
            "check": {
              "$ref": "#/$defs/check"
            },
            "unlockIds": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ]
    },
    "check": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string" },
        "all": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/check" }
        },
        "any": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/check" }
        }
      },
      "anyOf": [
        { "required": ["type"] },
        { "required": ["all"] },
        { "required": ["any"] }
      ]
    },
    "column": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "isPK": { "type": "boolean" },
        "isFK": { "type": "boolean" },
        "fkTarget": { "type": "string" }
      }
    },
    "table": {
      "type": "object",
      "additionalProperties": true,
      "required": ["columns", "rows"],
      "properties": {
        "columns": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              { "$ref": "#/$defs/column" }
            ]
          }
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array"
          }
        }
      }
    },
    "databaseSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "TABLES": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/table" }
        },
        "VIEWS": {
          "type": "object",
          "additionalProperties": true
        },
        "INDEXES": {
          "type": "object",
          "additionalProperties": true
        },
        "SCHEMAS": {
          "type": "object",
          "additionalProperties": true
        },
        "SEQUENCES": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "lesson": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title"],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "level": {
          "type": "number",
          "minimum": 1
        },
        "body": {
          "type": "string"
        },
        "tasks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/task"
          }
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lesson"
          }
        },
        "databaseProfile": {
          "type": "string"
        },
        "databaseSnapshot": {
          "$ref": "#/$defs/databaseSnapshot"
        }
      }
    }
  }
}
